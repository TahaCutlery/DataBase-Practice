<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ALL users</title>
</head>
<body>
    <h1>All users detail <button><a href="/">Count</a></button></h1>
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Username</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
          <%  for(let data of datas) {%>
                <tr>
                    <td><%= data.id %></td>
                    <td><%= data.username %></td>
                    <td><%= data.email %></td>
                    <td>
                        <button><a href="/user/<%= data.id %>/edit">Edit username</a></button>
                        <form method="post" action="/user/<%= data.id %>?_method=DELETE">
                            <button>Delete user</button>
                        </form>
                    </td>
                </tr>
           <% }%>
        </tbody>
    </table>
</body>
</html>